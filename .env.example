# Required: PostgreSQL database URL (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@localhost:5432/tempmail

# Required: Your domain (must have MX records pointing to Railway)
MAIL_DOMAIN=yourdomain.com

# Optional: Email expiry time in seconds (default: 300 = 5 minutes)
EMAIL_EXPIRY_SECONDS=300

# Optional: SMTP port (Railway may block 25, use 2525)
SMTP_PORT=2525

# Required: Port for FastAPI (Railway sets this automatically)
PORT=8000
